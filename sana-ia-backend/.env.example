# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=sana_db

# Database connection pool
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# Environment
NODE_ENV=development

# IA (Multi-provider: Gemini -> Groq -> cerebras -> SafeFallback)

# Primary provider (default: gemini)
LLM_PRIMARY_PROVIDER=gemini

# Ordered fallback chain (comma-separated, tried in order on RATE_LIMITED/UNAVAILABLE).
# LLM_FALLBACK_PROVIDER (single value) is still read as a legacy fallback if this is unset.
LLM_FALLBACK_CHAIN=groq,cerebras

# Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL_COLLECTING=gemini-2.5-flash-lite
GEMINI_MODEL_ANALYZING=gemini-2.5-flash
GEMINI_MODEL_COMPLETED=gemini-2.5-flash

# Groq API (fallback #1 — US-based, no credit card)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL_COLLECTING=llama-3.3-70b-versatile
GROQ_MODEL_ANALYZING=llama-3.3-70b-versatile
GROQ_MODEL_COMPLETED=llama-3.3-70b-versatile
# Vision model for multimodal/OCR prompts (llama-3.3 is text-only).
# qwen3.6-27b is Groq's supported multimodal model as of 2026-07;
# llama-3.2-*-vision-preview and llama-4-scout are deprecated — do NOT use them.
GROQ_MODEL_VISION=qwen/qwen3.6-27b

# Cerebras API (fallback #2 — US-based [Sunnyvale, CA], no credit card, text-only)
# Get free key at: https://cloud.cerebras.ai
# Cerebras has NO vision models — the resilient chain skips it for OCR prompts.
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
# llama3.1-8b for fast chat; llama-3.3-70b for deeper reasoning.
CEREBRAS_MODEL_COLLECTING=llama3.1-8b
CEREBRAS_MODEL_ANALYZING=llama3.1-8b
CEREBRAS_MODEL_COMPLETED=llama-3.3-70b

# LLM timeouts (ms) — shared across all providers
# timeoutFastMs: chat/collecting tier. timeoutSlowMs: OCR + completed tier.
GEMINI_TIMEOUT_FAST_MS=8000
GEMINI_TIMEOUT_SLOW_MS=30000

# LLM retry policy
# Primary provider (Gemini) retries deeply; fallback providers fail-fast
# because the fallback chain itself is the macro-level retry mechanism.
GEMINI_RETRY_MAX=2
GROQ_RETRY_MAX=0
CEREBRAS_RETRY_MAX=0
GEMINI_RETRY_BASE_MS=500
GEMINI_RETRY_CAP_MS=4000

# Rate limiting
CHAT_RATE_LIMIT_PER_MIN=12

# Redis (BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage (local disk or S3 — see src/storage/storage.module.ts)
STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=./uploads       # optional, defaults to ./uploads (STORAGE_TYPE=local)

# S3 (only read when STORAGE_TYPE=s3)
# S3_BUCKET=sana-ia-labs
# AWS_REGION=us-east-1
# S3_ENDPOINT=http://localhost:4566  # LocalStack only — omit against real AWS
