# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=sana_db

# Database connection pool
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# Environment
NODE_ENV=development

#IA (Gemini)
GEMINI_API_KEY=YOUR_API_KEY
GEMINI_MODEL_COLLECTING=gemini-2.0-flash-lite
GEMINI_MODEL_ANALYZING=gemini-2.0-flash
GEMINI_MODEL_COMPLETED=gemini-1.5-pro

# Gemini timeout (ms)
GEMINI_TIMEOUT_FAST_MS=8000
GEMINI_TIMEOUT_SLOW_MS=25000

# Gemini retry policy
GEMINI_RETRY_MAX=2
GEMINI_RETRY_BASE_MS=500
GEMINI_RETRY_CAP_MS=4000

# Rate limiting
CHAT_RATE_LIMIT_PER_MIN=12