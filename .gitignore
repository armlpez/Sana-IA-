# --- SAM build artifacts (regenerated by `sam build`) ---
infrastructure/.aws-sam/

# --- Personal deploy config — contains your VPC/subnet IDs and public IP ---
# Copy infrastructure/samconfig.toml.example to get started.
infrastructure/samconfig.toml

# --- OS ---
.DS_Store
Thumbs.db

# --- CLI/IDE artifacts, debug outputs, and temporary files ---
.atl/
.atlcheck.json

# --- Development/debug scripts and planning artifacts ---
# Local test batteries and manual E2E simulations
*.local.mjs
*.local.js
local-battery.mjs
e2e_simulation.*

# Scratch/exploration scripts (temporary development utilities)
scratch/list-models*.js
scratch/*.local.js

# Planning artifacts (should not be tracked; use docs/ for actual documentation)
**/implementation_plan.md.*
**/planning-*.md
**/*.resolved
**/*.draft

# Generated documentation artifacts (keep source .md files, not HTML)
functional-docs/*.html
docs/*.html
